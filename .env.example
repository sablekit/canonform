# --- LLM provider (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model id for generation — use a cheap one (Gemini Flash / GPT-4.1-mini / DeepSeek class)
CANONFORM_MODEL=

# --- Database (Postgres; e.g. Neon / Supabase / local) ---
# Example: postgresql://user:password@host:5432/canonform
DATABASE_URL=

# --- Cost guardrails (see ARCHITECTURE.md / SPEC §4) ---
DAILY_SPEND_CAP_USD=50
RATELIMIT_GEN_PER_IP_PER_MIN=10

# Adjust these names to match the implementation as you build.
